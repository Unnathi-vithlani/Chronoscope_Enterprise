# Database Configuration
DATABASE_URL=sqlite:///chronoscope.db
REDIS_URL=

# Kafka Configuration - disabled on free tier
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_THREAT_TOPIC=threats.raw
KAFKA_PROFILED_TOPIC=threats.profiled

# API Keys - add your own key from abuseipdb.com
ABUSEIPDB_KEY=359935c48340009b344c0ad7dac0c78b14ae93243267067a2df9ca3766c3c843c8dad04fd2b06a5b
URLHAUS_KEY=none

# Application Mode - set True for demo, False for live data
DEMO_MODE=True
ENVIRONMENT=production

# ML Configuration - disabled on free tier
MLFLOW_TRACKING_URI=
SPARK_MASTER=local[*]

# Scaling
MAX_WORKERS=2
BATCH_SIZE=50
